# Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/community_hero
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/community_hero

# ============================================================
# SECURITY
# ============================================================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# GOOGLE AI / GEMINI
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio

# ============================================================
# FIREBASE (Service Account JSON - paste content or path)
# ============================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# OR as inline JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ============================================================
# GOOGLE CLOUD STORAGE
# ============================================================
GCS_BUCKET_NAME=community-hero-media
GCS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# ============================================================
# REDIS (for WebSocket pub/sub and caching)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# FRONTEND URL (for CORS)
# ============================================================
FRONTEND_URL=http://localhost:3000

# ============================================================
# APP CONFIG
# ============================================================
APP_ENV=development
APP_NAME=Community Hero API
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# ============================================================
# GOOGLE MAPS (used by backend for reverse geocoding)
# ============================================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================
# DUPLICATE DETECTION
# ============================================================
DUPLICATE_RADIUS_METERS=100
DUPLICATE_SIMILARITY_THRESHOLD=0.8
